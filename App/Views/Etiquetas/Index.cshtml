@model IReadOnlyList<EtiquetaModelo>
@{
    ViewData["Title"] = "Etiquetas";
}

<h1 class="mb-3">Etiquetas</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Nueva etiqueta</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Activo</th>
            <th>Creado</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>
                    @if (item.Activo)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td>@item.FechaCreacion?.ToString("g")</td>
                <td class="text-end text-nowrap">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.IdEtiqueta" class="btn btn-outline-secondary" title="Ver"><i class="bi bi-eye" aria-hidden="true"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.IdEtiqueta" class="btn btn-outline-primary" title="Editar"><i class="bi bi-pencil-square" aria-hidden="true"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.IdEtiqueta" class="btn btn-outline-danger" title="Desactivar"><i class="bi bi-slash-circle" aria-hidden="true"></i></a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">No hay etiquetas registradas.</p>
}
