@model CategoriaModelo
@{
    ViewData["Title"] = "Desactivar categoría";
}

<h1>@ViewData["Title"]</h1>

<p class="text-muted">Por la relación con productos, la categoría no se elimina físicamente: solo se marca como inactiva.</p>

<hr />
<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10">@(Model.Activo ? "Sí" : "No")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.IdCategoria" method="post">
    <button type="submit" class="btn btn-danger">Confirmar desactivación</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</form>
