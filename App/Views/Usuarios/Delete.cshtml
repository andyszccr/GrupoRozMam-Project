@model UsuarioModelo
@{
    ViewData["Title"] = "Desactivar Usuario";
}

<h1>¿Estás seguro de desactivar este usuario?</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Usuario</dt>
        <dd class="col-sm-9">@Model.NombreUsuario</dd>

        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre @Model.Apellidos</dd>

        <dt class="col-sm-3">Correo</dt>
        <dd class="col-sm-9">@Model.Correo</dd>

        <dt class="col-sm-3">Rol</dt>
        <dd class="col-sm-9">@Model.NombreRol</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdUsuario" />
        <button type="submit" class="btn btn-danger">Confirmar Desactivación</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </form>
</div>
