@model List<UsuarioModelo>
@{
    ViewData["Title"] = "Usuarios";
}

<h1 class="mb-3">Usuarios</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Nuevo Usuario</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Nombre Completo</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Activo</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NombreUsuario</td>
                <td>@item.Nombre @item.Apellidos</td>
                <td>@item.Correo</td>
                <td>@item.NombreRol</td>
                <td>
                    @if (item.Activo)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td class="text-end text-nowrap">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.IdUsuario" class="btn btn-outline-secondary" title="Ver"><i class="bi bi-eye"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="btn btn-outline-primary" title="Editar"><i class="bi bi-pencil-square"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.IdUsuario" class="btn btn-outline-danger" title="Desactivar"><i class="bi bi-slash-circle"></i></a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">No hay usuarios registrados.</p>
}
