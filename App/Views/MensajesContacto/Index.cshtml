@model IReadOnlyList<MensajeContactoModelo>
@{
    ViewData["Title"] = "Mensajes de contacto";
}

<h1 class="mb-3">@ViewData["Title"]</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Asunto</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaEnvio.ToString("g")</td>
                <td>@item.NombreRemitente</td>
                <td>@item.CorreoRemitente</td>
                <td>@item.Asunto</td>
                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Atendido</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                </td>
                <td class="text-end text-nowrap">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.IdMensaje" class="btn btn-outline-secondary" title="Ver"><i class="bi bi-eye" aria-hidden="true"></i></a>
                        <a asp-action="Edit" asp-route-id="@item.IdMensaje" class="btn btn-outline-primary" title="Editar"><i class="bi bi-pencil-square" aria-hidden="true"></i></a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <p class="text-muted">No hay mensajes registrados.</p>
}
